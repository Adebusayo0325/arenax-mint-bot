# Fixes ERESOLVE build failure on Render (Node 26 / npm 11):
# @flashbots/ethers-provider-bundle@1.0.0 peer-depends on ethers@6.7.1,
# but this project requires ethers@^6.13.0. The installed 6.16.0 is
# fully compatible (Flashbots bundle only uses stable v6 provider APIs),
# so we relax npm's strict peer-dep resolution rather than downgrade ethers.
legacy-peer-deps=true
